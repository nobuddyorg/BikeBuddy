{
  // Linter rules; formatting (line length, table layout) is owned by Prettier.
  "config": {
    "default": true,
    "MD013": false, // line length — Prettier handles wrapping (proseWrap: preserve)
    "MD033": false, // allow inline HTML (badges, details)
    "MD041": false, // first line need not be a heading
    "MD024": { "siblings_only": true } // allow same heading text under different parents
  },
  "ignores": ["**/node_modules/**", "functions/coverage/**", "frontend/vendor/**"]
}
