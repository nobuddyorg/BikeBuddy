'use strict';
// Copy to config.js and fill in your values.
// config.js is gitignored — never commit the file with real values.
window.BIKEBUDDY_CONFIG = {
  // Leave empty for local dev (SWA CLI proxies /api/* to localhost:7071).
  // In production CI sets this to the Azure Functions URL.
  apiBaseUrl: '',
  // Microsoft Entra External ID tenant subdomain — e.g. "bikebuddy" for
  // bikebuddy.ciamlogin.com. Leave empty to run without auth (USE_DEV_AUTH).
  entraSubdomain: '',
  // Application (client) ID of the SPA app registration in the external tenant.
  entraClientId: '',
  // Scope the SPA requests for the API, e.g. api://<clientId>/access_as_user.
  entraApiScope: '',
  // Bypass MSAL and use the local dev user (pairs with SKIP_AUTH=true). Default
  // true: this file is only the local-dev template; CI generates its own
  // config.js with real values and devMode false.
  devMode: true,
};
