{
  "name": "bikebuddy-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "BikeBuddy frontend (static, no bundler) — dev tooling for tests only",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:ci": "vitest run --reporter=default --reporter=junit --outputFile=reports/unit-results.xml",
    "test:watch": "vitest",
    "test:e2e": "playwright test --config e2e/playwright.config.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "vitest": "^4.1.9"
  }
}
