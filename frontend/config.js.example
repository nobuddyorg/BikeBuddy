'use strict';
// Copy to config.js and fill in your values.
// config.js is gitignored — never commit the file with real values.
const BIKEBUDDY_CONFIG = {
  // Leave empty for local dev (SWA CLI proxies /api/* to localhost:7071).
  // In production this is set by CI to the Azure Functions URL, e.g.:
  //   https://bikebuddy-api.azurewebsites.net
  apiBaseUrl: '',
  // Full onmicrosoft.com domain (matches backend B2C_TENANT env var)
  b2cTenant: 'YOURTENANTNAME.onmicrosoft.com',
  // Client ID of the SPA app registration in B2C
  b2cClientId: 'YOUR_FRONTEND_APP_CLIENT_ID',
  // User flow name created in B2C (e.g. "B2C_1_signupsignin")
  b2cPolicy: 'B2C_1_signupsignin',
  // Scope exposed by the API app registration
  b2cApiScope:
    'https://YOURTENANTNAME.onmicrosoft.com/bikebuddy-api/user_impersonation',
  // Set to true locally (with SKIP_AUTH=true in local.settings.json) to bypass MSAL entirely.
  devMode: false,
};
