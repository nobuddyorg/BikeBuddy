{
  "name": "bikebuddy-e2e",
  "version": "1.0.0",
  "description": "Playwright end-to-end UI tests for BikeBuddy",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "playwright test --config playwright.fullstack.config.ts",
    "test:fullstack": "playwright test --config playwright.fullstack.config.ts",
    "format": "prettier --write '**/*.ts'",
    "format:check": "prettier --check '**/*.ts'"
  },
  "devDependencies": {
    "@azure/cosmos": "^4.1.1",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.0"
  }
}
