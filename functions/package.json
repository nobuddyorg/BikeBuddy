{
  "name": "bikebuddy-functions",
  "version": "1.0.0",
  "description": "BikeBuddy Azure Functions backend",
  "main": "src/**/index.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "func start",
    "start": "func start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=default --reporter=junit --outputFile.junit=reports/test-results.xml",
    "lint": "eslint src/ --no-error-on-unmatched-pattern",
    "format": "prettier --write 'src/**/*.js'"
  },
  "dependencies": {
    "@azure/cosmos": "^4.1.1",
    "@azure/functions": "^4.16.1",
    "@azure/storage-blob": "^12.25.0",
    "busboy": "^1.6.0",
    "exif-reader": "^2.0.3",
    "fast-xml-parser": "^5.9.3",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^4.1.0",
    "sharp": "^0.35.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-plugin-n": "^18.1.0",
    "globals": "^17.6.0",
    "prettier": "^3.4.2",
    "vitest": "^4.1.9"
  }
}
