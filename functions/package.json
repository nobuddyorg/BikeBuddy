{
  "name": "bikebuddy-functions",
  "version": "1.0.0",
  "description": "BikeBuddy Azure Functions backend",
  "main": "src/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently \"azurite --silent --location .azurite\" \"func start\"",
    "start": "func start",
    "test": "jest --runInBand",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@azure/cosmos": "^4.1.1",
    "@azure/storage-blob": "^12.25.0",
    "busboy": "^1.6.0",
    "fast-xml-parser": "^4.4.1",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "sharp": "^0.33.5",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "azurite": "^3.32.0",
    "concurrently": "^9.1.2",
    "eslint": "^8.57.1",
    "eslint-plugin-n": "^17.13.2",
    "jest": "^29.7.0",
    "prettier": "^3.4.2"
  }
}
